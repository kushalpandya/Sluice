# Local secrets for `wrangler dev`. Copy this file to `.env` (which is
# gitignored) and fill in real values. In production these are set instead with:
#   wrangler secret put APP_KEY
#   wrangler secret put ADMIN_KEY
#   wrangler secret put GITHUB_TOKEN

# Shared key the reporting app sends in the X-Report-Key header. Any random
# string for local testing; use a strong random value in production.
APP_KEY="dev-shared-key-change-me"

# Bearer token gating the /admin/* triage API. This is the sensitive one — it can
# read all reports and create issues. Use a strong random value in prod.
ADMIN_KEY="dev-admin-key-change-me"

# Fine-grained GitHub PAT with Issues: Read and write on the repo you promote to
# (set GITHUB_OWNER/GITHUB_REPO in wrangler.jsonc). Used only when you promote a
# report. Leave EMPTY to test everything except promotion.
GITHUB_TOKEN=""

# Deployed Worker origin, used by ./testreport.sh and ./seed.sh. No trailing
# slash. For a local `wrangler dev` run, either set this to http://127.0.0.1:8787
# or pass it as an arg: ./testreport.sh http://127.0.0.1:8787
BASE_URL=""
